@import 'nib'

// ==========================================
// 亚克力材质效果变量
// ==========================================
:root
  --acrylic-bg-light: rgba(255, 255, 255, 0.6)
  --acrylic-bg-dark: rgba(20, 20, 20, 0.6)
  --acrylic-blur: 20px
  --acrylic-saturate: 180%
  --acrylic-border-light: rgba(255, 255, 255, 0.4)
  --acrylic-border-dark: rgba(255, 255, 255, 0.1)

// ==========================================
// 顶部图 (一图流适配)
// ==========================================
#page-header
  background: transparent !important
  
  // 导航栏亚克力效果 (滚动时)
  &.nav-fixed #nav
    background: var(--acrylic-bg-light) !important
    backdrop-filter: blur(var(--acrylic-blur)) saturate(var(--acrylic-saturate))
    -webkit-backdrop-filter: blur(var(--acrylic-blur)) saturate(var(--acrylic-saturate))
    border-bottom: 1px solid var(--acrylic-border-light)

    [data-theme='dark'] &
      background: var(--acrylic-bg-dark) !important
      border-bottom: 1px solid var(--acrylic-border-dark)

  &.post-bg, &.not-home-page
    height: 280px !important
  #post-info
    bottom: 40px !important
    text-align: center
  #page-site-info
    top: 140px !important

  @media screen and (max-width: 768px)
    &.not-home-page
      height: 200px !important
    #post-info
      bottom: 10px !important
    #page-site-info
      top: 100px !important

.top-img
  height: 250px
  margin: -50px -40px 50px
  border-top-left-radius: inherit
  border-top-right-radius: inherit
  background-position: center
  background-size: cover
  transition: all .3s

  @media screen and (max-width: 768px)
    height: 230px
    margin: -36px -14px 36px

  [data-theme='dark'] &
    filter: brightness(.8)

// ==========================================
// 页脚 (亚克力效果)
// ==========================================
#footer
  background: transparent !important
  
  &:before
    background-color: var(--acrylic-bg-light) !important
    backdrop-filter: blur(var(--acrylic-blur)) saturate(var(--acrylic-saturate))
    -webkit-backdrop-filter: blur(var(--acrylic-blur)) saturate(var(--acrylic-saturate))
    
    [data-theme='dark'] &
      background-color: var(--acrylic-bg-dark) !important

#footer-wrap, #footer-wrap a
  color: #111
  transition: unset

  [data-theme='dark'] &
    color: var(--light-grey)

// ==========================================
// 内容区域透明化
// ==========================================
#content-inner, #wrap
  background: transparent !important

// ==========================================
// 卡片亚克力效果 (增强选择器)
// ==========================================
// 首页文章卡片、侧边栏卡片、文章详情页、归档页、分类页等
#recent-posts > .recent-post-items > .recent-post-item,
#aside-content .card-widget,
.layout > div:first-child:not(.recent-posts),
#aplayer-fixed,
.category-lists .category-list,
.tag-cloud-list a
  background-color: var(--acrylic-bg-light) !important
  backdrop-filter: blur(var(--acrylic-blur)) saturate(var(--acrylic-saturate))
  -webkit-backdrop-filter: blur(var(--acrylic-blur)) saturate(var(--acrylic-saturate))
  border: 1px solid var(--acrylic-border-light)
  box-shadow: 0 4px 16px 0 rgba(0, 0, 0, 0.1)
  transition: transform 0.3s ease, box-shadow 0.3s ease

  &:hover
    transform: translateY(-5px)
    box-shadow: 0 8px 24px rgba(0,0,0,0.15)

// 针对首页文章列表项的特殊处理（确保没有子元素覆盖背景）
#recent-posts > .recent-post-items > .recent-post-item
  border-radius: 12px

// 暗色模式卡片适配
[data-theme='dark']
  #recent-posts > .recent-post-items > .recent-post-item,
  #aside-content .card-widget,
  .layout > div:first-child:not(.recent-posts),
  #aplayer-fixed,
  .category-lists .category-list,
  .tag-cloud-list a
    background-color: var(--acrylic-bg-dark) !important
    border-color: var(--acrylic-border-dark)
    box-shadow: 0 4px 16px 0 rgba(0, 0, 0, 0.4)

// ==========================================
// 强制背景图
// ==========================================
#web_bg
  background-image: url('/img/bg.png') !important
  background-attachment: fixed !important
  background-size: cover !important
  background-position: center !important
  background-repeat: no-repeat !important
  opacity: 1 !important
  z-index: -999 !important
