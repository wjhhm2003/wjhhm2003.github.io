<tt xmlns="http://www.w3.org/ns/ttml" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" xmlns:tts="http://www.w3.org/ns/ttml#styling" xmlns:amll="http://www.example.com/ns/amll" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" itunes:timing="Word"><head><metadata><ttm:agent type="person" xml:id="v1"/><ttm:agent type="other" xml:id="v2"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><songwriters><songwriter>Yamato Kasai</songwriter><songwriter>Cassie Wei</songwriter><songwriter>かさい やまと</songwriter><songwriter>モモカシュー</songwriter><songwriter>Momocashew</songwriter></songwriters></iTunesMetadata><amll:meta key="musicName" value="TIAN TIAN"/><amll:meta key="musicName" value="Tian Tian"/><amll:meta key="artists" value="Mili"/><amll:meta key="artists" value="ミリー"/><amll:meta key="isrc" value="TCJPH2572234"/><amll:meta key="appleMusicId" value="1815866013"/><amll:meta key="album" value="Tian Tian - Single"/><amll:meta key="album" value="TIAN TIAN"/><amll:meta key="ncmMusicId" value="2707332868"/><amll:meta key="qqMusicId" value="003v41Cf199caK"/><amll:meta key="spotifyId" value="1gGqSeBtsWhphQNoj8cAuS"/><amll:meta key="ttmlAuthorGithub" value="139994896"/><amll:meta key="ttmlAuthorGithubLogin" value="wjhhm2003"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><translations><translation xml:lang="zh-CN"><text for="L11">往昔曾觉，万事皆是徒劳</text><text for="L12">唯有于苦难中，默默隐忍煎熬</text><text for="L13">且看我，步履不停</text><text for="L14">此行虽短，倒也明媚甘甜</text><text for="L15">心怀良善，循迹而行</text><text for="L16">无需辗转，莫走弯路</text><text for="L17">你我莫要忘却</text><text for="L18">生命本是，一场受邀而来的终身盛宴</text><text for="L19">若是贪杯不忍离席，未免有失风度</text><text for="L20">失了礼数，甚是不雅</text><text for="L23">无须介怀，了无挂碍</text><text for="L24">时辰已至，命途本就如此</text><text for="L34">我不再佯装，自己无动于衷</text><text for="L35">细品每一瞬光阴，所承载的重量</text><text for="L36">清风入肺微凉，流水平静澄澈</text><text for="L37">那是蛹中蝶梦正酣，亦是羽化后振翅之惊</text><text for="L38">纵能驰骋，与死神之轮竞速又如何？</text><text for="L39">倘若奔忙不息，便难觅沿途风景</text><text for="L40">愿藉我眼底这一方取景框，许你另一番解答</text><text for="L41">而我心深处的荒井，早已盈满爱意</text><text for="L42">且看我，步履不停</text><text for="L43">此行虽短，倒也明媚甘甜</text><text for="L44">心怀良善，循迹而行</text><text for="L45">无需辗转，莫走弯路</text><text for="L46">终有一日，我将归于尘土</text><text for="L47">莫要艳羡我，独享那份静谧长眠</text><text for="L48">此时我，嘴角正含着笑意</text><text for="L49">且请宽心，定请宽心</text><text for="L52">无须介怀，了无挂碍</text><text for="L53">时辰已至，命途本就如此</text></translation></translations></iTunesMetadata></metadata></head><body dur="04:01.450"><div begin="00:01.035" end="04:01.450"><p begin="00:01.035" end="00:04.723" ttm:agent="v1" itunes:key="L1"><span begin="00:01.035" end="00:01.322">今</span><span begin="00:01.322" end="00:01.691">天</span> <span begin="00:02.116" end="00:02.347">明</span><span begin="00:02.347" end="00:02.715">天</span> <span begin="00:03.027" end="00:03.333">期</span><span begin="00:03.333" end="00:03.726">待</span><span begin="00:04.111" end="00:04.355">每</span><span begin="00:04.355" end="00:04.723">天</span></p><p begin="00:05.074" end="00:07.722" ttm:agent="v1" itunes:key="L2"><span begin="00:05.074" end="00:05.255">不</span><span begin="00:05.255" end="00:05.786">需</span><span begin="00:06.327" end="00:06.827">要</span><span begin="00:06.827" end="00:07.249">永</span><span begin="00:07.249" end="00:07.722">远</span></p><p begin="00:09.104" end="00:12.732" ttm:agent="v1" itunes:key="L3"><span begin="00:09.104" end="00:09.371">阴</span><span begin="00:09.371" end="00:09.725">天</span> <span begin="00:10.061" end="00:10.378">晴</span><span begin="00:10.378" end="00:10.732">天</span> <span begin="00:11.104" end="00:11.366">无</span><span begin="00:11.366" end="00:11.706">论</span><span begin="00:12.104" end="00:12.340">哪</span><span begin="00:12.340" end="00:12.732">天</span></p><p begin="00:13.062" end="00:15.596" ttm:agent="v1" itunes:key="L4"><span begin="00:13.062" end="00:13.256">好</span><span begin="00:13.256" end="00:13.638">心</span><span begin="00:14.279" end="00:14.595">情</span><span begin="00:14.870" end="00:1